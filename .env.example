# ── App ──────────────────────────────────────────────────────────────
APP_NAME=Agent对话系统
APP_VERSION=0.1.0
DEBUG=true

# ── Database（与 docker-compose 对应）────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agent:agent_password@localhost:5432/agent_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS（前端开发地址）───────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── LLM（后续切片填写）────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── DocMind（阿里云文档解析）──────────────────────────────────────────
DOCMIND_ACCESS_KEY_ID=
DOCMIND_ACCESS_KEY_SECRET=

# ── Milvus ────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

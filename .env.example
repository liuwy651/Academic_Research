# ── App ──────────────────────────────────────────────────────────────
APP_NAME=Agent对话系统
APP_VERSION=0.1.0
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────
# 本地开发（后端直接运行）：
DATABASE_URL=postgresql+asyncpg://agent:agent_password@localhost:5432/agent_db
# Docker 全容器运行时此项由 docker-compose.yml 的 environment 块覆盖，无需修改

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── LLM ──────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=
# LLM_MODEL=qwen-turbo          # 非 Agent 路径的默认模型（对话标题等）
# LLM_TITLE_MODEL=qwen-turbo    # 标题生成轻量模型

# Agent 模型（按角色独立配置）
# AGENT_ROUTER_MODEL=deepseek-r1   # PrimaryRouter：带思考，用于意图识别和直接回答
# AGENT_WORKER_MODEL=qwen-plus     # CS_Researcher / Math_Analyst：不带思考，执行效率优先

# ── DocMind（阿里云文档解析）──────────────────────────────────────────
DOCMIND_ACCESS_KEY_ID=
DOCMIND_ACCESS_KEY_SECRET=

# ── Milvus ────────────────────────────────────────────────────────────
# 本地开发：
MILVUS_HOST=localhost
MILVUS_PORT=19530
# Docker 全容器运行时由 docker-compose.yml environment 块覆盖为 milvus:19530

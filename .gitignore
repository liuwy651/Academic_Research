# =========================
# 全局与机密文件 (Global & Secrets)
# =========================
.env
.env.*
!.env.example
.DS_Store
Thumbs.db

# =========================
# 编辑器与IDE (Editors & IDEs)
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/

# =========================
# 后端 (Backend - Python/uv/FastAPI)
# =========================
# 虚拟环境
backend/.venv/
# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class
# 如果有本地 SQLite 数据库文件
*.db
*.sqlite3

# =========================
# 前端 (Frontend - React/Vite)
# =========================
# 依赖包
frontend/node_modules/
# 构建产物
frontend/dist/
frontend/dist-ssr/
# 缓存文件
frontend/*.tsbuildinfo
frontend/.eslintcache
# npm/yarn 日志
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

frontend/public/